{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_read_channel",
      "mcp__claude_ai_Slack__slack_search_channels",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/reset-counter.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Slack__slack_send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/validate-report.py"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/search-guard.py"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block-domains.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-execution.py"
          }
        ]
      }
    ]
  }
}
